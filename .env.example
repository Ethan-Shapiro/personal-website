# Required for EthanLLM (components/EthanLLM.tsx, app/api/ethanllm/route.ts)
# Get a free-tier key at https://aistudio.google.com/apikey
GEMINI_API_KEY=...

# Optional — defaults to gemini-3.5-flash. This is a newly-launched model and can 503
# ("high demand") — the route automatically retries, then falls back to GEMINI_FALLBACK_MODEL.
GEMINI_MODEL=gemini-3.5-flash

# Optional — defaults to gemini-3.1-flash-lite (confirmed stable, no 404/503 issues in testing).
# Model availability varies per API key/account tier (e.g. gemini-2.5-flash 404'd as "no longer
# available to new users" even though it's still listed in the API's own model list) — if either
# model above 404s for you, call GET https://generativelanguage.googleapis.com/v1beta/models?key=YOUR_KEY
# to see what your key actually has access to, rather than trusting any hardcoded name here.
GEMINI_FALLBACK_MODEL=gemini-3.1-flash-lite
